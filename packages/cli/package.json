{
  "name": "@aproto9787/heddle",
  "version": "0.1.2",
  "description": "Local agent control plane for Claude Code, Codex, MCP tools, and repository workflows.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aproto9787/heddle.git",
    "directory": "packages/cli"
  },
  "homepage": "https://aproto9787.github.io/heddle/",
  "bugs": {
    "url": "https://github.com/aproto9787/heddle/issues"
  },
  "keywords": [
    "heddle",
    "ai-agents",
    "coding-agents",
    "claude-code",
    "codex",
    "mcp",
    "model-context-protocol",
    "local-first",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "heddle": "dist/index.js",
    "heddle-subagent": "dist/subagent-launcher.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "node scripts/pack-examples.mjs copy",
    "postpack": "node scripts/pack-examples.mjs clean",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@aproto9787/heddle-core": "workspace:^",
    "@aproto9787/heddle-mcp": "workspace:^",
    "@aproto9787/heddle-runtime": "workspace:^",
    "yaml": "^2.8.3"
  }
}
