{
  "name": "@aproto9787/heddle-workspace",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "check": "pnpm -r build && pnpm -r typecheck",
    "publish:npm:core": "pnpm --filter @aproto9787/heddle-core publish --access public",
    "publish:npm:runtime": "pnpm --filter @aproto9787/heddle-runtime publish --access public",
    "publish:npm:mcp": "pnpm --filter @aproto9787/heddle-mcp publish --access public",
    "publish:npm:cli": "pnpm --filter @aproto9787/heddle publish --access public",
    "publish:npm": "pnpm publish:npm:core && pnpm publish:npm:runtime && pnpm publish:npm:mcp && pnpm publish:npm:cli"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
